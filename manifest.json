{
  "manifest_version": 3,
  "name": "Fix in Claude for Bugbot",
  "version": "0.1.0",
  "description": "Adds a 'Fix in Claude' button to Cursor Bugbot comments on GitHub PRs",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["dist/content.global.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
